# Copy to .env and fill in with your own values. Never commit the real .env.

# --- Main LLM (any OpenAI-compatible endpoint) ---
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=your-llm-api-key
LLM_MODEL=your-model-name

# --- Guardrail model (safety classifier, e.g. Llama Guard) — can be a
# DIFFERENT provider/endpoint than the main LLM above ---
GUARD_BASE_URL=https://your-guardrail-provider.example.com/v1
GUARD_API_KEY=your-guardrail-api-key
GUARD_MODEL=your-guardrail-model-name

# --- Web search ---
TAVILY_API_KEY=your-tavily-api-key

# --- Observability (optional — leave LANGSMITH_TRACING=false to disable) ---
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=stock-analyzer

# --- App ---
APP_ENV=development
LOG_LEVEL=INFO
